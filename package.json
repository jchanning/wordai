{
  "name": "wordai-frontend",
  "version": "1.0.0",
  "description": "WordAI frontend static assets — linting only, no build step",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint \"src/main/resources/static/js/**/*.js\"",
